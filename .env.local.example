# Copiá este archivo como .env.local y completá los valores.
# .env.local NO se sube a git (está en .gitignore).

# Clave secreta de Django para producción. Generá una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# 0 = producción (sin debug). En local podés dejarlo sin definir (queda 1).
DEBUG=0

# Hosts permitidos separados por coma (además de *.vercel.app).
# Ej: midominio.com,www.midominio.com
ALLOWED_HOSTS=

# Orígenes CSRF de confianza separados por coma (incluí https://).
# Ej: https://midominio.com
CSRF_TRUSTED_ORIGINS=

# Orígenes permitidos para el front (Next.js) separados por coma.
# Ej: https://mi-front.vercel.app
CORS_ALLOWED_ORIGINS=

# Cadena de conexión a Postgres (Neon). Para correr migraciones desde tu PC
# usá la URL UNPOOLED (directa) de Neon.
DATABASE_URL=
